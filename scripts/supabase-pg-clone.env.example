# Copiar a supabase-pg-clone.local.env (no commitear).
#
# !!! NO uses https://xxxxx.supabase.co (eso es la API, no PostgreSQL).
#
# Donde copiar: Supabase -> Project Settings -> Database -> Connection string -> URI
#
# ---------------------------------------------------------------------------
# OPCION A - Direct (db....supabase.co:5432)
# Si en Windows ves "Connection timed out" con IPv6, usa OPCION B.
# postgresql://postgres:CONTRASENA@db.TUREF.supabase.co:5432/postgres
#
# OPCION B - Session pooler (recomendado si Direct falla por red/firewall)
# En el mismo apartado, elige "Session pooler" y copia la URI.
# El usuario suele ser postgres.TUREF (no solo postgres).
# Host tipo: aws-0-REGION.pooler.supabase.com o aws-1-REGION.pooler.supabase.com
# Puerto: 5432  (NO uses Transaction :6543 para pg_dump)
#
# ---------------------------------------------------------------------------
# REF origen: hoqigshqvbnlicuvirpo | REF destino: orqimjobjvtsyjhxjiup
# Sustituye REGION y contrasenas por los valores del dashboard de cada proyecto.

# Ejemplo Direct (si te conecta):
# SUPABASE_DB_SOURCE_URL=postgresql://postgres:CONTRASENA_ORIGEN@db.hoqigshqvbnlicuvirpo.supabase.co:5432/postgres
# SUPABASE_DB_TARGET_URL=postgresql://postgres:CONTRASENA_DESTINO@db.orqimjobjvtsyjhxjiup.supabase.co:5432/postgres

# Ejemplo Session pooler (copia la URI exacta del dashboard; region puede variar):
# SUPABASE_DB_SOURCE_URL=postgresql://postgres.hoqigshqvbnlicuvirpo:CONTRASENA_ORIGEN@aws-0-us-east-1.pooler.supabase.com:5432/postgres
# SUPABASE_DB_TARGET_URL=postgresql://postgres.orqimjobjvtsyjhxjiup:CONTRASENA_DESTINO@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# OPCION C - Si ves "password authentication failed for user postgres" pero el usuario es postgres.REF:
# La contrasena puede tener @ : # u otros caracteres que rompen la URI. Pon la clave aparte y deja la URL SIN clave:
# SUPABASE_DB_SOURCE_URL=postgresql://postgres.hoqigshqvbnlicuvirpo@aws-0-us-west-2.pooler.supabase.com:5432/postgres
# SUPABASE_DB_SOURCE_PASSWORD=tu_clave_completa_sin_corchetes
# SUPABASE_DB_TARGET_URL=postgresql://postgres.orqimjobjvtsyjhxjiup@aws-1-us-east-1.pooler.supabase.com:5432/postgres
# SUPABASE_DB_TARGET_PASSWORD=tu_clave_completa_sin_corchetes

SUPABASE_DB_SOURCE_URL=
SUPABASE_DB_TARGET_URL=
